# LMS Portal Environment Variables

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Database (Supabase/Postgres)
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.supabase.co:5432/lms

# Redis
REDIS_URL=redis://localhost:6379

# Google Drive Proxy
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=eyJ... (base64 Service Account JSON)

# Blockchain
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
PRIVATE_KEY=0x...
ETHERSCAN_API_KEY=...

# Supabase anon/service keys (for frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...

